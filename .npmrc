@vxture:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
; GitHub Packages serves package tarballs from a /download/ path. Without
; always-auth, npm omits the token on that tarball request and the download
; fails with "401 - authentication token not provided"; force auth on every
; request to the registry so tarball fetches carry the token too.
always-auth=true
