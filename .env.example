# -- Node Identity -------------------------------------------------------------
PROJECT_NAME=umbra
NODE_NAME=vx-tokyo

# -- Server Paths --------------------------------------------------------------
ROOT_DIR=/srv/vxture
REPO_DIR=/srv/vxture/repo/umbra
DATA_DIR=/srv/vxture/data/umbra
BACKUP_DIR=/srv/vxture/backup/umbra

# -- Domains -------------------------------------------------------------------
APEX_DOMAIN=ruyin.ai
WWW_DOMAIN=www.ruyin.ai
EDGE_DOMAIN=vpn.ruyin.ai
SUB_DOMAIN=sub.ruyin.ai
CONSOLE_DOMAIN=console.ruyin.ai
ADMIN_DOMAIN=admin.ruyin.ai
PASS_DOMAIN=pass.ruyin.ai

# -- Xray / REALITY ------------------------------------------------------------
XRAY_INTERNAL_PORT=10443
REALITY_DEST=www.microsoft.com:443
REALITY_SNI=www.microsoft.com
# Must be an even number; generates REALITY_SHORT_ID_LENGTH/2 random bytes as hex
REALITY_SHORT_ID_LENGTH=16

# -- Marzban -------------------------------------------------------------------
MARZBAN_ADMIN_USER=
MARZBAN_ADMIN_PASSWORD=
# public = trusted CA certs; private = temporary self-signed certs while waiting for LE rate limits
MARZBAN_SSL_CA_TYPE=public
# Base URL for subscription links - no trailing slash
SUBSCRIPTION_URL_PREFIX=https://sub.ruyin.ai
# Prefix used by umbra-subproxy for client-visible names: Ruyin-USERNAME.
SUB_PROFILE_PREFIX=Ruyin
# Upstream Marzban fallback title; subproxy rewrites the public response.
SUB_PROFILE_TITLE=Ruyin

# -- Account Portal ------------------------------------------------------------
# Generate each secret separately: openssl rand -base64 48
ACCOUNT_SESSION_SECRET=
ACCOUNT_INVITE_SECRET=
ACCOUNT_INVITE_TTL_DAYS=30
# Built-in admin portal (admin.ruyin.ai) credential, independent of Marzban.
ACCOUNT_ADMIN_USERNAME=
ACCOUNT_ADMIN_PASSWORD=
# Vxture unified account SSO. JWT secret must match auth-bff.
# accounts.vxture.com is the single identity center for the whole product
# (ruyin.ai + every business app); console.vxture.com is no longer an auth host.
JWT_SECRET=
AUTH_BFF_URL=
AUTH_INTERNAL_TOKEN=
VXTURE_LOGIN_URL=https://accounts.vxture.com/signin
# Vxture SSO start endpoint. Set empty to keep fallback login behavior.
VXTURE_SSO_URL=https://accounts.vxture.com/sso/start
# Parent domain the session cookie is rewritten onto so one login is shared
# across ruyin.ai and every *.ruyin.ai app (apex; the leading-dot is implied).
RUYIN_COOKIE_DOMAIN=ruyin.ai

# -- OIDC RP (Vxture App Integration Standard v1.0) ----------------------------
# ruyin is a cross-domain (mode B) OIDC Authorization-Code + PKCE RP against
# accounts.vxture.com. The console portal is the RP / app-bff: it holds tokens
# server-side in Redis and the browser only ever sees an opaque session cookie.
# Leave OIDC_ISSUER / OIDC_CLIENT_SECRET empty to keep the legacy SSO path
# active (the new endpoints stay dormant until both are set).
OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=ruyin
# Provisioned by the platform via secret manager; never commit the real value.
OIDC_CLIENT_SECRET=
# Must exactly match a registered redirect_uri on the ruyin oidc_client.
OIDC_REDIRECT_URI=https://ruyin.ai/auth/callback
OIDC_SCOPES=openid profile ruyin
OIDC_POST_LOGOUT_REDIRECT_URI=https://ruyin.ai/
# Server-side OIDC RP session store (umbra-redis on the compose network).
REDIS_URL=redis://umbra-redis:6379
# RP session lifetime in seconds (keep <= refresh TTL; default 30d).
RP_SESSION_TTL=2592000
# Opaque session cookie name + the first-party zone it is shared across.
RP_SESSION_COOKIE_NAME=vx_rp_session
RP_SESSION_COOKIE_DOMAIN=.ruyin.ai

# -- Vaultwarden ---------------------------------------------------------------
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# -- Certbot -------------------------------------------------------------------
CERTBOT_EMAIL=
# Set to true to use Let's Encrypt staging (untrusted certs, for pre-DNS testing)
CERTBOT_STAGING=false
# Set to true to skip certbot and use self-signed certs (no DNS required).
# Upgrade to real certs later: bash scripts/ops.sh certs --upgrade
CERTBOT_SKIP=false

# -- Post-deploy user creation (deploy.sh wizard) --------------------------------
USER_COUNT=10
USER_PREFIX=USER

# -- Nginx ---------------------------------------------------------------------
NGINX_CONTAINER=umbra-nginx

# -- Container Images ----------------------------------------------------------
# Production worker nodes should point IMAGE_REGISTRY to Aliyun ACR.
# Example: registry.cn-hangzhou.aliyuncs.com
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest

# -- Private packages ----------------------------------------------------------
# Published package source for @vxture/design-system.
# GitHub Packages default: https://npm.pkg.github.com
VXTURE_NPM_REGISTRY=https://npm.pkg.github.com
# Token with package read access. Keep only in .env or CI secrets.
NODE_AUTH_TOKEN=
